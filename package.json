{
  "name": "signal-morph",
  "version": "0.1.1",
  "private": false,
  "main": "./dist/signal-morph/public-api.mjs",
  "module": "./dist/signal-morph/public-api.mjs",
  "types": "./dist/signal-morph/public-api.d.mts",
  "exports": {
    ".": {
      "types": "./dist/signal-morph/public-api.d.mts",
      "import": "./dist/signal-morph/public-api.mjs"
    }
  },
  "files": [
    "dist/signal-morph",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UeberTimei/signal-morph.git"
  },
  "author": "UeberTimei",
  "license": "MIT",
  "keywords": [
    "angular",
    "signals",
    "reactivity",
    "morph",
    "pipe",
    "operators",
    "unix"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ui": "ng test --ui",
    "lint": "oxlint projects/",
    "lint:fix": "oxlint projects/ --fix",
    "format": "oxfmt projects/ --write",
    "format:check": "oxfmt projects/ --check",
    "build:lib": "tsdown",
    "release": "changeset publish",
    "version:lib": "changeset version",
    "prepare": "husky"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@changesets/cli": "^2.31.0",
    "@vitest/ui": "^4.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.4",
    "ng-packagr": "^21.2.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "tsdown": "0.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "packageManager": "bun@1.3.9",
  "peerDependencies": {
    "@angular/core": ">=16.0.0"
  },
  "lint-staged": {
    "projects/**/*.{js,ts}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  }
}
